rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Secure Game Room rules
    match /rooms/{roomId} {
      // Enable direct fetching of active game rooms by ID
      allow get: if true;
      
      // Strict block against query-scanning and brute forcing list of all rooms
      allow list: if false;

      // Create new room documents
      allow create: if request.resource.data.id is string
                    && request.resource.data.hostId is string
                    && request.resource.data.status == "setup";

      // Update room actions - allow participants to synchronize game state changes
      allow update: if true;

      // Block total deletion of active games over raw interfaces
      allow delete: if false;
    }
  }
}
